# Digit-Hab — API Django (Gunicorn systemd ou Docker sur 3004)
# /media/* doit être servi par Caddy AVANT le reverse_proxy (sinon 404 Django).
api.digit-hab.wolofdigital.site {
	handle /media/* {
		root * /opt/apps/digit-hab-api
		file_server
	}
	handle {
		reverse_proxy 127.0.0.1:3004
	}
}
